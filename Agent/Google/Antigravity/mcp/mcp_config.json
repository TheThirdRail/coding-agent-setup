{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "startup_timeout_sec": 25,
      "tool_timeout_sec": 120,
      "args": [
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "antigravity"
      ]
    },
    "MCP_DOCKER": {
      "command": "docker.exe",
      "startup_timeout_sec": 30,
      "tool_timeout_sec": 120,
      "args": [
        "mcp",
        "gateway",
        "run",
        "--transport",
        "stdio",
        "--registry",
        "__HYBRID_REGISTRY_PATH__",
        "--additional-catalog",
        "D:/Coding/Tools/mcp-docker-stack/MCP-Servers/mcp-docker-stack/docker-mcp-catalog.runtime.yaml"
      ]
    }
  }
}
