# ==============================================================================
# MCP DOCKER STACK - EXAMPLE ENV FOR THE CURRENT HYBRID MCP PLAN
# ==============================================================================
# Copy this file to .env and fill in only the values you actually need.
#
# This template is aligned to the current stack:
# - direct always-on MCP servers in Codex / Antigravity client config
# - Docker gateway used only for lazy-load supplementals
#
# This file is primarily consumed by:
# - MCP-Servers/scripts/install-mcp-servers.ps1
# - MCP-Servers/scripts/set-mcp-secrets.ps1
#
# IMPORTANT:
# - Never commit your real .env file.
# - Leave unused values blank.
# - The secret-sync script skips blank values.
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED FOR THE CURRENT STACK
# ------------------------------------------------------------------------------

# Self-hosted SearXNG endpoint used by the `searxng` server.
# Windows + Docker Desktop default when SearXNG is bound to localhost:8080:
SEARXNG_URL=http://host.docker.internal:8080


# ------------------------------------------------------------------------------
# COMMON OPTIONAL LAZY-LOAD SUPPLEMENTALS
# ------------------------------------------------------------------------------

# github-official
# Create at: https://github.com/settings/personal-access-tokens/new
# Typical useful scopes: repo, workflow, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=


# ------------------------------------------------------------------------------
# OPTIONAL RESEARCH / CRAWLING
# ------------------------------------------------------------------------------

# firecrawl
# Pricey and optional.
FIRECRAWL_API_KEY=


# ------------------------------------------------------------------------------
# OPTIONAL DIRECT-CLIENT-ONLY VARIABLES
# ------------------------------------------------------------------------------

# These are not currently consumed by MCP-Servers/scripts/set-mcp-secrets.ps1.
# Keep them here only if you decide to wire a direct client config to them.

# context7
# Optional if you want higher limits or authenticated direct Context7 access.
CONTEXT7_API_KEY=
